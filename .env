.testing1# Data source for the event dataset.
#  - A value starting with "https" is fetched over the network at runtime
#    (proxied by the dev/preview server to avoid CORS — see vite.config.ts).
#  - A relative path (e.g. ./events.json) is loaded from the local server (public/).
# Both modes produce identical application behaviour.
VITE_DATA_SOURCE=./events.json
